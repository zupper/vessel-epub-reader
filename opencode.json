{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["CLAUDE.md"],
  "permission": {
    "external_directory": "deny",
    "read": "allow",
    "edit": "ask",
    "write": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "bash": {
      "*": "ask",

      "ls *": "allow",
      "pwd *": "allow",
      "cd *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "less *": "allow",
      "more *": "allow",
      "tree *": "allow",
      "find *": "allow",
      "which *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "wc *": "allow",
      "du *": "allow",
      "df *": "allow",

      "grep *": "allow",
      "rg *": "allow",
      "ag *": "allow",
      "sed *": "allow",
      "awk *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "diff *": "allow",
      "cut *": "allow",
      "tr *": "allow",

      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "git show *": "allow",
      "git stash list *": "allow",
      "git remote *": "allow",
      "git tag *": "allow",
      "git blame *": "allow",
      "git shortlog *": "allow",
      "git rev-parse *": "allow",
      "git ls-files *": "allow",
      "git ls-tree *": "allow",
      "git cat-file *": "allow",
      "git describe *": "allow",

      "node *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "bun *": "allow",
      "pnpm *": "allow",
      "yarn *": "allow",
      "tsc *": "allow",

      "docker ps *": "allow",
      "docker logs *": "allow",
      "docker images *": "allow",
      "docker inspect *": "allow",

      "curl *": "allow",
      "wget *": "allow",
      "jq *": "allow",
      "yq *": "allow",

      "echo *": "allow",
      "printf *": "allow",
      "env *": "allow",
      "printenv *": "allow",
      "date *": "allow",
      "whoami *": "allow",
      "uname *": "allow",

      "xargs *": "ask",
      "sudo *": "deny",
      "su *": "deny"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "morph": {
      "type": "local",
      "command": ["npx", "-y", "@morphllm/morphmcp"]
    }
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".json",
        ".css",
        ".scss",
        ".md",
        ".yaml",
        ".yml"
      ]
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp",
    "opencode-websearch-cited",
    "opencode-supermemory",
    "oh-my-opencode",
    "@zenobius/opencode-skillful"
  ]
}
